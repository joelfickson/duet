# LLM Provider API Keys (at least one required, or use BYOK in the UI)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Server
PORT=8000
DATABASE_PATH=./data/duet.db

# Client
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Rate limiting
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=10000

# Reconnection
RECONNECT_GRACE_MS=60000
